---
const {
  title = 'Remote Astro Component',
  description = 'Rendered from astro_remote/RemoteCard',
} = Astro.props;
---

<article class="remote-card">
  <h2>{title}</h2>
  <p>{description}</p>
</article>

<style>
  .remote-card {
    border: 1px solid rgba(15, 23, 42, 0.2);
    border-radius: 12px;
    background: linear-gradient(145deg, #fff, #f8fafc);
    padding: 1rem;
  }

  h2 {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
  }

  p {
    margin: 0;
    color: #334155;
  }
</style>
