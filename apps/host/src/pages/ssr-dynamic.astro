---
import Layout from '../layouts/Layout.astro';

const remote = await import('astro_remote/server');
const message = remote.getRemoteServerMessage({
	from: 'Astro frontmatter dynamic import',
});
---

<Layout title="Astro Host - SSR Dynamic Import">
	<main>
		<h1>Astro Host (SSR dynamic import)</h1>
		<p id="ssr-dynamic-message">{message}</p>
		<p><a href="/">Back to CSR page</a></p>
	</main>
</Layout>

<style>
	main {
		font-family: ui-sans-serif, system-ui, sans-serif;
		max-width: 760px;
		margin: 0 auto;
		padding: 3rem 1rem;
	}
</style>
