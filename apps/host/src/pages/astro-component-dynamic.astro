---
import Layout from '../layouts/Layout.astro';

const { default: RemoteCard } = await import('astro_remote/RemoteCard');
---

<Layout title="Astro Host - Remote Astro Component Dynamic Import">
  <main>
    <h1>Remote Astro Component (SSR dynamic import)</h1>
    <section class="page-note">
      <h2>What this page does</h2>
      <p>
        This page uses <code>await import('astro_remote/RemoteCard')</code> in Astro frontmatter,
        then renders the returned default export as <code>&lt;RemoteCard /&gt;</code>. This is the
        SSR component path for dynamic imports.
      </p>
      <pre class="snippet"><code><span class="token keyword">const</span> <span class="token punctuation">{</span> <span class="token keyword">default</span><span class="token punctuation">:</span> <span class="token variable">RemoteCard</span> <span class="token punctuation">}</span> <span class="token operator">=</span> <span class="token keyword">await</span> <span class="token keyword">import</span><span class="token punctuation">(</span><span class="token string">'astro_remote/RemoteCard'</span><span class="token punctuation">)</span><span class="token punctuation">;</span>

<span class="token tag">&lt;RemoteCard</span>
  <span class="token attr">title</span><span class="token operator">=</span><span class="token string">"RemoteCard via dynamic import"</span>
  <span class="token attr">description</span><span class="token operator">=</span><span class="token string">"Loaded in Astro frontmatter with await import() and rendered as &lt;RemoteCard /&gt;."</span>
<span class="token tag">/&gt;</span></code></pre>
    </section>
    <section class="remote-boundary boundary-dynamic">
      <p class="boundary-label">Dynamic remote component boundary</p>
      <RemoteCard
        title="RemoteCard via dynamic import"
        description="Loaded in Astro frontmatter with await import() and rendered as <RemoteCard />."
      />
    </section>
    <p><a href="/">Back to CSR page</a></p>
  </main>
</Layout>

<style>
  main {
    font-family: ui-sans-serif, system-ui, sans-serif;
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 1rem;
  }

  h1 {
    margin: 0 0 1rem;
  }

  .page-note {
    border: 1px solid rgba(15, 23, 42, 0.16);
    border-radius: 14px;
    background: #f8fafc;
    padding: 1rem;
    margin: 0 0 1rem;
  }

  .page-note h2 {
    margin: 0 0 0.5rem;
    font-size: 1rem;
  }

  .remote-boundary {
    position: relative;
    margin: 1rem 0 0;
    padding: 1.25rem 1rem 1rem;
    border: 2px dashed #f59e0b;
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(255, 251, 235, 0.92), rgba(255, 255, 255, 0.96));
    box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.08);
  }

  .boundary-label {
    position: absolute;
    top: -0.75rem;
    left: 0.9rem;
    margin: 0;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    background: #78350f;
    color: #fef3c7;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .page-note .snippet {
    margin: 0.75rem 0 0;
    padding: 0.85rem 1rem;
    border-radius: 12px;
    background: #0f172a;
    color: #e2e8f0;
    overflow-x: auto;
  }

  .page-note .snippet code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.95rem;
  }

  .token.keyword,
  .token.attr {
    color: #7dd3fc;
  }

  .token.string {
    color: #86efac;
  }

  .token.tag {
    color: #f9a8d4;
  }

  .token.variable {
    color: #f8fafc;
  }

  .token.operator,
  .token.punctuation {
    color: #94a3b8;
  }
</style>
