---
import Layout from '../layouts/Layout.astro';

const { default: RemoteCard } = await import('astro_remote/RemoteCard');
---

<Layout title="Astro Host - Remote Astro Component Dynamic Import">
  <main>
    <h1>Remote Astro Component (SSR dynamic import)</h1>
    <RemoteCard
      title="RemoteCard via dynamic import"
      description="Loaded in Astro frontmatter with await import() and rendered as <RemoteCard />."
    />
    <p><a href="/">Back to CSR page</a></p>
  </main>
</Layout>

<style>
  main {
    font-family: ui-sans-serif, system-ui, sans-serif;
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 1rem;
  }

  h1 {
    margin: 0 0 1rem;
  }
</style>
