---
import Layout from "../layouts/Layout.astro";
import RemoteCard from "astro_remote/RemoteCard";
---

<Layout title="Astro Host - Remote Astro Component">
  <main>
    <h1>Remote Astro Component</h1>
    <section class="page-note">
      <h2>What this page does</h2>
      <p>
        This page statically imports <code>astro_remote/RemoteCard</code> in Astro frontmatter and
        renders it as <code>&lt;RemoteCard /&gt;</code>. The component HTML is produced during SSR.
      </p>
      <pre class="snippet"><code><span class="token keyword">import</span> <span class="token variable">RemoteCard</span> <span class="token keyword">from</span> <span class="token string">'astro_remote/RemoteCard'</span><span class="token punctuation">;</span>

<span class="token tag">&lt;RemoteCard</span>
  <span class="token attr">title</span><span class="token operator">=</span><span class="token string">"RemoteCard from astro_remote"</span>
  <span class="token attr">description</span><span class="token operator">=</span><span class="token string">"Imported with Astro syntax and rendered in host."</span>
<span class="token tag">/&gt;</span></code></pre>
    </section>
    <section class="remote-boundary boundary-static">
      <p class="boundary-label">Static remote component boundary</p>
      <RemoteCard
        title="RemoteCard from astro_remote"
        description="Imported with Astro syntax and rendered in host."
      />
    </section>
    <p><a href="/">Back to CSR page</a></p>
  </main>
</Layout>

<style>
  main {
    font-family: ui-sans-serif, system-ui, sans-serif;
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 1rem;
  }

  h1 {
    margin: 0 0 1rem;
  }

  .page-note {
    border: 1px solid rgba(15, 23, 42, 0.16);
    border-radius: 14px;
    background: #f8fafc;
    padding: 1rem;
    margin: 0 0 1rem;
  }

  .page-note h2 {
    margin: 0 0 0.5rem;
    font-size: 1rem;
  }

  .remote-boundary {
    position: relative;
    margin: 1rem 0 0;
    padding: 1.25rem 1rem 1rem;
    border: 2px dashed #10b981;
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(236, 253, 245, 0.9), rgba(255, 255, 255, 0.96));
    box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.08);
  }

  .boundary-label {
    position: absolute;
    top: -0.75rem;
    left: 0.9rem;
    margin: 0;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    background: #064e3b;
    color: #d1fae5;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .page-note .snippet {
    margin: 0.75rem 0 0;
    padding: 0.85rem 1rem;
    border-radius: 12px;
    background: #0f172a;
    color: #e2e8f0;
    overflow-x: auto;
  }

  .page-note .snippet code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.95rem;
  }

  .token.keyword,
  .token.attr {
    color: #7dd3fc;
  }

  .token.string {
    color: #86efac;
  }

  .token.tag {
    color: #f9a8d4;
  }

  .token.variable {
    color: #f8fafc;
  }

  .token.operator,
  .token.punctuation {
    color: #94a3b8;
  }
</style>
