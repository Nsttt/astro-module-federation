{
  "name": "@module-federation/astro",
  "version": "0.0.1",
  "type": "module",
  "description": "Astro integration for Module Federation using @module-federation/vite",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p ./tsconfig.json",
    "test": "pnpm run build && node --test ./test/*.test.mjs"
  },
  "dependencies": {
    "@module-federation/runtime": "^2.1.0",
    "@module-federation/sdk": "^2.1.0",
    "@module-federation/vite": "^1.12.0"
  },
  "peerDependencies": {
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}
